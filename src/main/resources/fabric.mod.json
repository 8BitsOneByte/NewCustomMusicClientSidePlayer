{
  "schemaVersion": 1,
  "id": "newcustommusicclientsideplayer",
  "version": "${version}",

  "name": "NewCustomMusicClientSidePlayer",
  "description": "A client-side Minecraft music player for custom music from resource packs.",
  "authors": [
    "8BitsOneByte"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/new-custom-music-client-side-player" ,
    "sources": "https://github.com/8BitsOneByte/NewCustomMusicClientSidePlayer/tree/master",
    "issues": "https://github.com/8BitsOneByte/NewCustomMusicClientSidePlayer/issues"
  },

  "license": "MIT",
  "icon": "assets/newcustommusicclientsideplayer/icon.png",

  "environment": "client",
  "entrypoints": {
    "fabric-datagen": ["org.exmple.newcustommusicclientsideplayer.client.bootstrap.NewcustommusicclientsideplayerDataGenerator"],
    "client": ["org.exmple.newcustommusicclientsideplayer.client.bootstrap.NewcustommusicclientsideplayerClient"],
    "main": ["org.exmple.newcustommusicclientsideplayer.Newcustommusicclientsideplayer"]
  },

  "mixins": [
    "newcustommusicclientsideplayer.mixins.json"
    ,{
      "config": "newcustommusicclientsideplayer.client.mixins.json",
      "environment": "client"
    }
  ],

  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
